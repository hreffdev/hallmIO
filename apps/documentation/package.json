{
	"name": "@hallm/docs",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "bun run build:pre && next build && bun run build:post",
		"build:pre": "bun ./scripts/pre-build.ts",
		"build:post": "bun ./scripts/post-build.ts",
		"dev": "next dev --turbopack --port 3031",
		"start": "next start",
		"postinstall": "fumadocs-mdx",
		"check:spelling": "cspell -c .cspell.jsonc --no-progress --no-summary --no-must-find-files --unique --cache",
		"typegen": "fumadocs-mdx && next typegen",
		"typecheck": "bun run typegen && tsc --noEmit",
		"with-env": "dotenv -e ../../.env --",
		"prepare": "lefthook install"
	},
	"dependencies": {
		"@hallm/ui": "workspace:*",
		"@ai-sdk/openai": "^3.0.25",
		"@ai-sdk/react": "^3.0.71",
		"@bprogress/next": "^3.2.12",
		"@fumadocs/mdx-remote": "^1.4.4",
		"@next/bundle-analyzer": "16.1.6",
		"@next/env": "16.1.6",
		"@shikijs/rehype": "^3.22.0",
		"@shikijs/transformers": "^3.22.0",
		"@t3-oss/env-nextjs": "^0.13.10",
		"@takumi-rs/image-response": "^0.66.13",
		"ai": "^6.0.69",
		"class-variance-authority": "catalog:ui",
		"clsx": "catalog:ui",
		"feed": "^5.2.0",
		"fumadocs-core": "^16.5.0",
		"fumadocs-docgen": "^3.0.5",
		"fumadocs-mdx": "^14.2.6",
		"fumadocs-openapi": "^10.3.1",
		"fumadocs-twoslash": "^3.1.12",
		"fumadocs-typescript": "^5.1.1",
		"fumadocs-ui": "^16.5.0",
		"hast-util-to-jsx-runtime": "^2.3.6",
		"jiti": "^2.6.1",
		"katex": "^0.16.28",
		"lucide-react": "^0.563.0",
		"mermaid": "^11.12.2",
		"motion": "^12.31.0",
		"next": "16.1.6",
		"next-themes": "^0.4.6",
		"oxc-transform": "^0.56.5",
		"react": "catalog:react",
		"react-dom": "catalog:react",
		"rehype-katex": "^7.0.1",
		"remark": "^15.0.1",
		"remark-gfm": "^4.0.1",
		"remark-math": "^6.0.0",
		"remark-mdx": "^3.1.1",
		"remark-rehype": "^11.1.2",
		"remark-stringify": "^11.0.0",
		"rimraf": "^6.1.2",
		"shiki": "^3.22.0",
		"tailwind-merge": "catalog:ui:",
		"tw-animate-css": "catalog:ui:",
		"twoslash": "^0.3.6",
		"unist-util-visit": "^5.1.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@hallm/tsconfig": "workspace:*",
		"@types/bun": "catalog:types",
		"@types/hast": "^3.0.4",
		"@types/mdx": "^2.0.13",
		"@types/node": "catalog:types",
		"@types/react": "catalog:types",
		"@types/react-dom": "catalog:types",
		"chokidar": "^5.0.0",
		"cspell": "^9.6.4",
		"gray-matter": "^4.0.3",
		"next-validate-link": "^1.6.4",
		"@tailwindcss/postcss": "catalog:ui",
		"shadcn": "catalog:ui",
		"source-map-support": "^0.5.21",
		"tailwindcss": "catalog:ui",
		"tinyglobby": "^0.2.15",
		"ts-morph": "^27.0.2",
		"typescript": "catalog:types"
	}
}
