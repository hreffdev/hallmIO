{
	"extends": "@hallm/tsconfig/nextjs.json",
	"compilerOptions": {
		"target": "ESNext",
		"lib": [
			"dom",
			"dom.iterable",
			"esnext"
		],
		"baseUrl": ".",
		"paths": {
			"@/*": [
				"./src/*"
			],
			"fumadocs-mdx:collections/*": [
				".source/*"
			]
		},
		"plugins": [
			{
				"name": "next"
			}
		],
		"ignoreDeprecations": "5.0",
		"strictNullChecks": true
	},
	"include": [
		"next-env.d.ts",
		"**/*.ts",
		"**/*.mts",
		"**/*.tsx",
		".next/types/**/*.ts",
		".next/dev/types/**/*.ts",
		"next.config.ts"
	],
	"exclude": [
		"node_modules"
	]
}
